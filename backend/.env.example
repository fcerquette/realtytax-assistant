PORT=3001

# Ollama (free, local) - default config
OLLAMA_BASE_URL=http://localhost:11434/v1
AI_MODEL=llama3.1

# Supabase (free tier)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key-here

